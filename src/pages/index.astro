---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle";
import Hero from "../components/sections/Hero.astro";
import About from "../components/sections/About.astro";
import Skills from "../components/sections/Skills.astro";
import Experience from "../components/sections/Experience.astro";
import Contact from "../components/sections/Contact.astro";
import { SERVICES } from "../data/services";
import Icon from "../components/icons/Icon.astro";
---

<Layout
	title="Vlad Setchin — Senior Full Stack Engineer (.NET/C#, Azure) & AI Systems Architect"
	description="Senior Full Stack Software Engineer specialising in .NET/C#, Azure, and AI agent systems. Available for senior roles, freelance, and consulting."
>
	<ThemeToggle slot="theme-toggle" client:load />
	<Hero />
	<About />
	<Skills />
	<Experience />

	<!-- Services teaser -->
	<section id="services" class="section">
		<div class="container">
			<h2 class="section__title">
				<span class="section__title-icon"><Icon name="gear" size={18} /></span>
				<span class="section__title-text">Services</span>
			</h2>
			<div class="teaser-grid">
				{
					SERVICES.map((s) => (
						<a href={`${import.meta.env.BASE_URL}services/`} class="teaser-card">
							<div class="teaser-card__icon">
								<Icon name={s.icon} size={24} />
							</div>
							<h3 class="teaser-card__title">{s.title}</h3>
							<p class="teaser-card__desc">{s.description}</p>
						</a>
					))
				}
			</div>
			<a href={`${import.meta.env.BASE_URL}services/`} class="teaser-cta"
				>View all services →</a
			>
		</div>
	</section>

	<Contact />
</Layout>

<style>
	.teaser-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: var(--space-4);
		margin-bottom: var(--space-6);
	}

	.teaser-card {
		display: block;
		padding: var(--space-6);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg, 0.75rem);
		text-decoration: none;
		color: inherit;
		transition:
			transform 0.12s ease,
			border-color 0.12s ease,
			box-shadow 0.12s ease;
	}

	.teaser-card:hover {
		border-color: var(--color-accent);
		transform: translateY(-2px);
		box-shadow: var(--card-hover-shadow);
	}

	.teaser-card__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm, 0.25rem);
		color: var(--color-accent);
		margin-bottom: var(--space-3);
		background: var(--color-bg);
	}

	.teaser-card__title {
		font-size: var(--text-lg);
		margin-bottom: var(--space-2);
		color: var(--color-heading);
	}

	.teaser-card__desc {
		color: var(--color-text-muted);
		font-size: var(--text-sm);
		line-height: 1.6;
	}

	.teaser-cta {
		font-weight: 600;
		color: var(--color-accent);
		font-size: var(--text-base);
	}
</style>
