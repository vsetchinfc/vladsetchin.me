---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle';
---

<Layout 
  title="Vlad Setchin — Software Engineer" 
  description="Personal website and blog of Vlad Setchin"
>
  <ThemeToggle slot="theme-toggle" client:load />
  
  <div class="container" style="padding-top: var(--space-16); padding-bottom: var(--space-16);">
    <h1 style="text-align: center; margin-bottom: var(--space-8);">
      Welcome to <span style="color: var(--color-accent);">vladsetchin.me</span>
    </h1>
    
    <div style="max-width: 600px; margin: 0 auto; text-align: center;">
      <p style="font-size: var(--text-lg); margin-bottom: var(--space-6);">
        This is a placeholder home page for the new Astro-powered site.
      </p>
      <p style="color: var(--color-text-muted);">
        Content sections (hero, about, skills, contact) will be added in Task 2.
      </p>
    </div>
  </div>
</Layout>
