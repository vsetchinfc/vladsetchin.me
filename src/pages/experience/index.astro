---
import { EXPERIENCE } from "../../data/experience";
import { SITE } from "../../data/site";
import Layout from "../../layouts/Layout.astro";
---

<Layout
	title="Experience — Vlad Setchin"
	description="25+ years of full-stack engineering across medical, educational, field service, utilities, retail, and wholesale — from startups to enterprise scale."
>
	<div
		class="container"
		style="padding-top: var(--space-16); padding-bottom: var(--space-24);"
	>
		<h1 style="margin-bottom: var(--space-4);">Experience</h1>
		<p class="experience-intro">
			25+ years of full-stack engineering across medical, educational, field
			service, utilities, retail, and wholesale — from startups to enterprise
			scale.
		</p>

		<div class="timeline">
			{
				EXPERIENCE.map((role) => (
					<article class="timeline__item">
						<div class="timeline__meta">
							<span class="timeline__period">{role.period}</span>
						</div>
						<div class="timeline__body">
							<h2 class="timeline__role">{role.title}</h2>
							<p class="timeline__company">{role.company}</p>
							<p class="timeline__summary">{role.summary}</p>
							<ul class="timeline__highlights">
								{role.highlights.map((h) => <li>{h}</li>)}
							</ul>
							<ul class="timeline__tags">
								{role.tech.map((t) => (
									<li>[ {t} ]</li>
								))}
							</ul>
						</div>
					</article>
				))
			}
		</div>

		<div class="experience-cta">
			<h2 style="margin-bottom: var(--space-4);">Want the full picture?</h2>
			<p
				style="color: var(--color-text-muted); margin-bottom: var(--space-6); font-size: var(--text-lg);"
			>
				Get in touch and I'll send over my CV.
			</p>
			<a href={`mailto:${SITE.email}`} class="cta-btn">Get in touch</a>
			<a
				href={SITE.linkedin}
				target="_blank"
				rel="noopener noreferrer"
				class="cta-btn cta-btn--secondary"
			>
				Connect on LinkedIn
			</a>
		</div>
	</div>
</Layout>

<style>
	.experience-intro {
		font-size: var(--text-xl);
		color: var(--color-text-muted);
		max-width: 640px;
		margin-bottom: var(--space-12);
		line-height: 1.7;
	}

	.timeline {
		display: flex;
		flex-direction: column;
		gap: var(--space-12);
		margin-bottom: var(--space-16);
	}

	.timeline__item {
		display: grid;
		grid-template-columns: 160px 1fr;
		gap: var(--space-8);
		padding-bottom: var(--space-12);
		border-bottom: 1px solid var(--color-border);
	}

	.timeline__item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.timeline__period {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		white-space: nowrap;
	}

	.timeline__role {
		font-size: var(--text-xl);
		color: var(--color-heading);
		margin-bottom: var(--space-1);
	}

	.timeline__company {
		color: var(--color-accent);
		font-weight: 600;
		font-size: var(--text-base);
		margin-bottom: var(--space-3);
	}

	.timeline__summary {
		color: var(--color-text-muted);
		font-size: var(--text-base);
		line-height: 1.7;
		margin-bottom: var(--space-4);
		max-width: 700px;
	}

	.timeline__highlights {
		list-style: none;
		padding: 0;
		margin: 0 0 var(--space-4) 0;
		max-width: 700px;
	}

	.timeline__highlights li {
		color: var(--color-text-muted);
		font-size: var(--text-sm);
		padding: var(--space-1) 0;
		padding-left: var(--space-4);
		position: relative;
		line-height: 1.6;
	}

	.timeline__highlights li::before {
		content: "→";
		position: absolute;
		left: 0;
		color: var(--color-accent);
		font-size: var(--text-xs);
		top: 0.5em;
	}

	.timeline__tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		padding: 0;
		margin: 0;
	}

	.timeline__tags li {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		padding: var(--space-1) var(--space-2);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-surface);
		white-space: nowrap;
	}

	.experience-cta {
		border-top: 1px solid var(--color-border);
		padding-top: var(--space-12);
		text-align: center;
	}

	.cta-btn {
		display: inline-flex;
		align-items: center;
		padding: var(--space-3) var(--space-8);
		border-radius: var(--radius-md, 0.5rem);
		font-weight: 600;
		font-size: var(--text-base);
		text-decoration: none;
		transition: opacity 0.2s ease;
		margin: var(--space-2);
	}

	.cta-btn:hover {
		opacity: 0.85;
	}

	.cta-btn:not(.cta-btn--secondary) {
		background: var(--color-accent);
		color: #04130c;
	}

	.cta-btn--secondary {
		border: 1px solid var(--color-border);
		color: var(--color-text);
	}

	@media (max-width: 640px) {
		.timeline__item {
			grid-template-columns: 1fr;
			gap: var(--space-3);
		}
	}
</style>
