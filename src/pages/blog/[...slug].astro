---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import GiscusComments from "../../components/GiscusComments";
import { SITE } from "../../data/site";

export async function getStaticPaths() {
	const posts = await getCollection("blog", ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
	return date.toLocaleDateString("en-AU", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}

const blogPostSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: post.data.title,
	description: post.data.description,
	datePublished: post.data.pubDate.toISOString(),
	dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
	author: { "@type": "Person", name: SITE.title, url: SITE.url },
	url: `${SITE.url}/blog/${post.slug}/`,
});
---

<Layout
	title={`${post.data.title} - Vlad Setchin`}
	description={post.data.description}
	ogType="article"
	ogImage={post.data.heroImage}
	pubDate={post.data.pubDate}
	jsonLd={blogPostSchema}
>
	<article class="container post">
		<header class="post__header">
			<div class="post__meta">
				<time datetime={post.data.pubDate.toISOString()}>
					{formatDate(post.data.pubDate)}
				</time>
				{
					post.data.updatedDate && (
						<span class="post__updated">
							Updated:{" "}
							<time datetime={post.data.updatedDate.toISOString()}>
								{formatDate(post.data.updatedDate)}
							</time>
						</span>
					)
				}
			</div>
			<h1 class="post__title">{post.data.title}</h1>
			<p class="post__description">{post.data.description}</p>
			{
				post.data.tags.length > 0 && (
					<div class="post__tags" aria-label="Tags">
						{post.data.tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				)
			}
		</header>

		<div class="prose">
			<Content />
		</div>

		<footer class="post__footer">
			<a href={`${import.meta.env.BASE_URL}blog/`} class="back-link"
				>← Back to blog</a
			>
		</footer>

		<GiscusComments client:visible />
	</article>
</Layout>

<style>
	.post {
		padding-top: var(--space-12);
		padding-bottom: var(--space-16);
		max-width: var(--content-width, 720px);
	}

	.post__header {
		margin-bottom: var(--space-12);
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--color-border);
	}

	.post__meta {
		display: flex;
		gap: var(--space-4);
		flex-wrap: wrap;
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		margin-bottom: var(--space-4);
	}

	.post__updated {
		color: var(--color-text-muted);
	}

	.post__title {
		font-size: clamp(1.75rem, 5vw, var(--text-4xl));
		margin-bottom: var(--space-3);
	}

	.post__description {
		font-size: var(--text-xl);
		color: var(--color-text-muted);
		margin-bottom: var(--space-4);
		line-height: 1.5;
	}

	.post__tags {
		display: flex;
		gap: var(--space-2);
		flex-wrap: wrap;
	}

	.tag {
		font-size: var(--text-xs);
		padding: 2px var(--space-2);
		border-radius: var(--radius-sm, 0.25rem);
		background: var(--color-surface);
		color: var(--color-text-muted);
		border: 1px solid var(--color-border);
	}

	.post__footer {
		margin-top: var(--space-16);
		padding-top: var(--space-8);
		border-top: 1px solid var(--color-border);
	}

	.back-link {
		color: var(--color-text-muted);
		font-size: var(--text-sm);
	}

	/* Prose styles for blog content */
	.prose {
		font-size: var(--text-lg);
		line-height: 1.8;
		color: var(--color-text);
	}

	.prose :global(h2) {
		font-size: var(--text-2xl);
		margin-top: var(--space-12);
		margin-bottom: var(--space-4);
		padding-top: var(--space-4);
	}

	.prose :global(h3) {
		font-size: var(--text-xl);
		margin-top: var(--space-8);
		margin-bottom: var(--space-3);
	}

	.prose :global(p) {
		margin-bottom: var(--space-6);
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin-bottom: var(--space-6);
		padding-left: var(--space-6);
	}

	.prose :global(li) {
		margin-bottom: var(--space-2);
	}

	.prose :global(a) {
		color: var(--color-accent);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.prose :global(blockquote) {
		border-left: 3px solid var(--color-accent);
		padding-left: var(--space-6);
		margin: var(--space-8) 0;
		color: var(--color-text-muted);
		font-style: italic;
	}

	.prose :global(pre) {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md, 0.5rem);
		padding: var(--space-6);
		overflow-x: auto;
		margin-bottom: var(--space-6);
		font-size: var(--text-sm);
	}

	.prose :global(code) {
		font-family: var(--font-mono);
	}

	.prose :global(hr) {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: var(--space-12) 0;
	}

	.prose :global(img) {
		max-width: 100%;
		border-radius: var(--radius-md, 0.5rem);
	}
</style>
