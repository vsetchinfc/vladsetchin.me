---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/icons/Icon.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date) {
	return date.toLocaleDateString("en-AU", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}
---

<Layout
	title="Blog — Vlad Setchin"
	description="Writing on .NET, Azure, AI agent systems, and building software that lasts."
>
	<div
		class="container"
		style="padding-top: var(--space-16); padding-bottom: var(--space-16);"
	>
		<h1 class="section__title" style="margin-bottom: var(--space-2);">
			<span class="section__title-icon"><Icon name="pen" size={18} /></span>
			<span class="section__title-text">Blog</span>
		</h1>
		<p
			style="color: var(--color-text-muted); margin-bottom: var(--space-12); font-size: var(--text-lg);"
		>
			Writing on .NET, Azure, AI agent systems, and building software that lasts.
		</p>

		{
			posts.length === 0 ? (
				<p style="color: var(--color-text-muted);">
					No posts yet — check back soon.
				</p>
			) : (
				<ul class="post-list">
					{posts.map((post) => (
						<li class="post-item">
							<a
								href={`${import.meta.env.BASE_URL}blog/${post.slug}/`}
								class="post-link"
							>
								<article>
									<div class="post-icon">
										<Icon name="pen" size={20} />
									</div>
									<time
										class="post-date"
										datetime={post.data.pubDate.toISOString()}
									>
										{formatDate(post.data.pubDate)}
									</time>
									<h2 class="post-title">{post.data.title}</h2>
									<p class="post-description">{post.data.description}</p>
									{post.data.tags.length > 0 && (
										<div class="post-tags" aria-label="Tags">
											{post.data.tags.map((tag) => (
												<span class="tag">{tag}</span>
											))}
										</div>
									)}
								</article>
							</a>
						</li>
					))}
				</ul>
			)
		}
	</div>
</Layout>

<style>
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-8);
	}

	.post-link {
		display: block;
		padding: var(--space-6);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg, 0.75rem);
		text-decoration: none;
		color: inherit;
		transition:
			border-color 0.2s ease,
			transform 0.1s ease;
	}

	.post-link:hover {
		border-color: var(--color-accent);
		transform: translateY(-2px);
		opacity: 1;
	}

	.post-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm, 0.25rem);
		color: var(--color-accent);
		margin-bottom: var(--space-3);
		background: var(--color-bg);
	}

	.post-date {
		display: block;
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		margin-bottom: var(--space-2);
	}

	.post-title {
		font-size: var(--text-2xl);
		margin-bottom: var(--space-2);
		color: var(--color-heading);
	}

	.post-description {
		color: var(--color-text-muted);
		line-height: 1.6;
		margin-bottom: var(--space-3);
	}

	.post-tags {
		display: flex;
		gap: var(--space-2);
		flex-wrap: wrap;
	}

	.tag {
		font-size: var(--text-xs);
		padding: 2px var(--space-2);
		border-radius: var(--radius-sm, 0.25rem);
		background: var(--color-surface);
		color: var(--color-text-muted);
		border: 1px solid var(--color-border);
	}
</style>
