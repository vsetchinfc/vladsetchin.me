---
import { SKILLS } from "../../data/skills";
import Icon from "../icons/Icon.astro";
---

<section id="skills" class="section">
	<div class="container">
		<h2 class="section__title">
			<span class="section__title-icon"><Icon name="cpu" size={18} /></span>
			<span class="section__title-text">Skills</span>
		</h2>
		<div class="skills__grid">
			{
				SKILLS.map((group) => (
					<div class="skills__group">
						<h3 class="skills__category">
							<span class="skills__category-icon">
								<Icon name={group.icon} size={18} />
							</span>
							{group.category}
						</h3>
						<ul class="skills__list">
							{group.items.map((item) => (
								<li class="skills__item">[{item}]</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.skills__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: var(--space-6);
		margin-top: var(--space-6);
	}

	.skills__group {
		min-width: 0;
		padding: var(--space-6);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg, 0.75rem);
		background: var(--color-surface);
		transition:
			border-color 0.15s ease,
			transform 0.12s ease;
	}

	.skills__group:hover {
		border-color: var(--color-accent);
		transform: translateY(-2px);
	}

	.skills__category {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		font-size: var(--text-base);
		font-weight: 700;
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: var(--space-3);
	}

	.skills__category-icon {
		display: inline-flex;
		color: var(--color-accent);
	}

	.skills__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.skills__item {
		font-size: var(--text-sm);
		color: var(--color-text);
		padding: var(--space-1) var(--space-3);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
		line-height: 1.4;
		white-space: normal;
		overflow-wrap: break-word;
		transition:
			border-color 0.15s ease,
			color 0.15s ease;
	}

	.skills__item:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}
</style>
