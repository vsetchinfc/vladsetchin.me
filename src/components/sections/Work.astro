---
import { EXPERIENCE } from "../../data/experience";
import Icon from "../icons/Icon.astro";

const featured = EXPERIENCE.slice(0, 3);
---

<section id="work" class="section">
	<div class="container">
		<h2 class="section__title">
			<span class="section__title-icon"><Icon name="briefcase" size={18} /></span>
			<span class="section__title-text">Selected Work</span>
		</h2>
		<div class="experience__list">
			{
				featured.map((role) => (
					<div class="experience__item">
						<div class="experience__marker"><span class="experience__dot"></span></div>
						<div class="experience__body">
							<h3 class="experience__role">{role.product}</h3>
							<p class="experience__summary">{role.summary}</p>
							<ul class="experience__tags">
								{role.tech.slice(0, 4).map((t) => (
									<li>[ {t} ]</li>
								))}
							</ul>
						</div>
					</div>
				))
			}
		</div>
		<a href={`${import.meta.env.BASE_URL}work/`} class="experience__cta"
			>View full work history →</a
		>
	</div>
</section>

<style>
	.experience__list {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: var(--space-8);
		margin-top: var(--space-6);
		margin-bottom: var(--space-8);
	}

	.experience__list::before {
		content: "";
		position: absolute;
		top: 6px;
		bottom: 6px;
		left: 10px;
		width: 1px;
		background: var(--color-border);
	}

	.experience__item {
		display: grid;
		grid-template-columns: 20px 1fr;
		column-gap: var(--space-6);
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--color-border);
	}

	.experience__item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.experience__marker {
		position: relative;
		display: flex;
		justify-content: center;
	}

	.experience__dot {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: var(--color-accent);
		box-shadow: 0 0 0 3px var(--color-bg), 0 0 8px rgba(0, 224, 138, 0.45);
		margin-top: 0.35em;
		position: relative;
		z-index: 1;
	}

	.experience__role {
		font-size: var(--text-lg);
		color: var(--color-heading);
		margin-bottom: var(--space-3);
	}

	.experience__summary {
		color: var(--color-text-muted);
		font-size: var(--text-base);
		line-height: 1.7;
		margin-bottom: var(--space-3);
		max-width: 640px;
	}

	.experience__tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		padding: 0;
		margin: 0;
	}

	.experience__tags li {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		padding: var(--space-1) var(--space-2);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-surface);
		white-space: nowrap;
	}

	.experience__cta {
		font-weight: 600;
		color: var(--color-accent);
		font-size: var(--text-base);
	}

	@media (max-width: 640px) {
		.experience__item {
			grid-template-columns: 1fr;
			gap: var(--space-2);
		}

		.experience__marker,
		.experience__list::before {
			display: none;
		}
	}
</style>
