---
import { SITE } from "../../data/site";
---

<section id="hero" class="hero">
	<div class="container hero__inner">
		<div class="terminal">
			<div class="terminal__bar">
				<span class="terminal__dot terminal__dot--red"></span>
				<span class="terminal__dot terminal__dot--yellow"></span>
				<span class="terminal__dot terminal__dot--green"></span>
				<span class="terminal__title">vlad@agistra — zsh</span>
			</div>
			<div class="terminal__body">
				<p class="terminal__prompt">whoami</p>

				<h1 class="hero__eyebrow">
					Hi, I'm <span class="hero__name">Vlad</span>
				</h1>

				<p class="hero__tagline">{SITE.tagline}</p>
				<p class="hero__bio">
					<span class="hero__bio-marker">#</span> .NET/C# and Azure engineer with a growing focus
					on production AI agent systems. Available for senior engineering roles, freelance,
					and consulting.
				</p>
				<p class="terminal__prompt">stats --summary</p>
				<dl class="hero__stats">
					<div class="hero__stat">
						<dt>years_experience</dt>
						<dd>25+</dd>
					</div>
					<div class="hero__stat">
						<dt>test_coverage</dt>
						<dd>96%+</dd>
					</div>
					<div class="hero__stat">
						<dt>projects_shipped</dt>
						<dd>150+</dd>
					</div>
					<div class="hero__stat">
						<dt>industries</dt>
						<dd>6</dd>
					</div>
				</dl>

				<div class="hero__ctas">
					<a href="#projects" class="btn btn--primary">View work</a>
					<a href="#contact" class="btn btn--secondary">Get in touch</a>
				</div>
				<p class="terminal__cursor" aria-hidden="true">_</p>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		padding: var(--space-24) 0 var(--space-16);
		min-height: 80vh;
		display: flex;
		align-items: center;
	}

	.hero__inner {
		max-width: var(--content-width, 760px);
		position: relative;
	}

	.hero__inner::before {
		content: "";
		position: absolute;
		inset: -15% -10%;
		background: radial-gradient(
			ellipse 60% 50% at 50% 35%,
			rgba(0, 224, 138, 0.14),
			transparent 70%
		);
		z-index: -1;
		pointer-events: none;
	}

	[data-theme="light"] .hero__inner::before {
		background: radial-gradient(
			ellipse 60% 50% at 50% 35%,
			rgba(6, 122, 78, 0.1),
			transparent 70%
		);
	}

	.terminal {
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
		overflow: hidden;
		position: relative;
	}

	.terminal::after {
		content: "";
		position: absolute;
		inset: 0;
		background: repeating-linear-gradient(
			to bottom,
			rgba(255, 255, 255, 0.03) 0px,
			rgba(255, 255, 255, 0.03) 1px,
			transparent 1px,
			transparent 3px
		);
		mix-blend-mode: overlay;
		pointer-events: none;
		z-index: 1;
	}

	.terminal__bar,
	.terminal__body > *:not(.terminal__cursor) {
		animation: terminal-reveal 0.4s ease-out backwards;
	}

	.terminal__bar {
		animation-delay: 0s;
	}

	.terminal__body > *:nth-child(1) {
		animation-delay: 0.12s;
	}

	.terminal__body > *:nth-child(2) {
		animation-delay: 0.22s;
	}

	.terminal__body > *:nth-child(3) {
		animation-delay: 0.32s;
	}

	.terminal__body > *:nth-child(4) {
		animation-delay: 0.42s;
	}

	.terminal__body > *:nth-child(5) {
		animation-delay: 0.52s;
	}

	.terminal__body > *:nth-child(6) {
		animation-delay: 0.62s;
	}

	.terminal__body > *:nth-child(7) {
		animation-delay: 0.72s;
	}

	@keyframes terminal-reveal {
		from {
			opacity: 0;
			transform: translateY(6px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.terminal__bar,
		.terminal__body > * {
			animation: none;
		}
	}

	.terminal__bar {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-3) var(--space-4);
		background: rgba(127, 127, 127, 0.04);
		border-bottom: 1px solid var(--color-border);
	}

	.terminal__dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		display: inline-block;
	}

	.terminal__dot--red {
		background: #ff5f56;
	}

	.terminal__dot--yellow {
		background: #ffbd2e;
	}

	.terminal__dot--green {
		background: #27c93f;
	}

	.terminal__title {
		margin-left: var(--space-2);
		font-size: var(--text-xs);
		color: var(--color-text-muted);
	}

	.terminal__body {
		padding: var(--space-8) var(--space-8) var(--space-6);
	}

	.terminal__prompt {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		margin-bottom: var(--space-6);
	}

	.terminal__prompt::before {
		content: "$ ";
		color: var(--color-accent);
	}

	.hero__eyebrow {
		color: var(--color-accent);
		font-size: var(--text-lg);
		font-weight: 600;
		margin-bottom: var(--space-2);
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.hero__name {
		font-size: clamp(2.5rem, 8vw, var(--text-5xl));
		margin-bottom: var(--space-4);
		line-height: 1.05;
		color: var(--color-text);
		text-transform: none;
	}

	.hero__tagline {
		font-size: var(--text-2xl);
		color: var(--color-text-muted);
		margin-bottom: var(--space-4);
		font-weight: 500;
	}

	.hero__bio {
		font-size: var(--text-base);
		color: var(--color-text-muted);
		max-width: 560px;
		margin-bottom: var(--space-8);
		line-height: 1.7;
	}

	.hero__bio-marker {
		color: var(--color-accent);
	}

	.hero__stats {
		display: grid;
		grid-template-columns: repeat(2, auto);
		gap: var(--space-2) var(--space-6);
		margin: 0 0 var(--space-8);
		font-size: var(--text-sm);
	}

	.hero__stat {
		display: flex;
		gap: var(--space-2);
	}

	.hero__stat dt {
		color: var(--color-text-muted);
	}

	.hero__stat dt::after {
		content: ":";
	}

	.hero__stat dd {
		color: var(--color-accent);
		font-weight: 600;
	}

	.hero__ctas {
		display: flex;
		gap: var(--space-4);
		flex-wrap: wrap;
		margin-bottom: var(--space-6);
	}

	.terminal__cursor {
		color: var(--color-accent);
		font-size: var(--text-lg);
		animation: blink 1.1s steps(1) infinite;
	}

	@keyframes blink {
		50% {
			opacity: 0;
		}
	}

	.btn {
		display: inline-flex;
		align-items: center;
		padding: var(--space-3) var(--space-6);
		border-radius: var(--radius);
		font-weight: 600;
		font-size: var(--text-base);
		transition:
			opacity 0.2s ease,
			transform 0.1s ease;
		text-decoration: none;
	}

	.btn:hover {
		opacity: 0.85;
		transform: translateY(-1px);
	}

	.btn--primary {
		background: var(--color-accent);
		color: #04130c;
	}

	.btn--secondary {
		border: 1px solid var(--color-border);
		color: var(--color-text);
		background: transparent;
	}

	@media (max-width: 640px) {
		.hero {
			min-height: auto;
			padding: var(--space-16) 0 var(--space-12);
		}

		.terminal__body {
			padding: var(--space-6) var(--space-5) var(--space-5);
		}
	}
</style>
