---
import { EXPERIENCE } from "../../data/experience";

const featured = EXPERIENCE.slice(0, 3);
---

<section id="experience" class="section">
	<div class="container">
		<h2 class="section__title">Experience</h2>
		<div class="experience__list">
			{
				featured.map((role) => (
					<div class="experience__item">
						<div class="experience__period">{role.period}</div>
						<div class="experience__body">
							<h3 class="experience__role">
								{role.title} <span class="experience__company">@ {role.company}</span>
							</h3>
							<p class="experience__summary">{role.summary}</p>
							<ul class="experience__tags">
								{role.tech.slice(0, 4).map((t) => (
									<li>[ {t} ]</li>
								))}
							</ul>
						</div>
					</div>
				))
			}
		</div>
		<a href={`${import.meta.env.BASE_URL}experience/`} class="experience__cta"
			>View full experience →</a
		>
	</div>
</section>

<style>
	.experience__list {
		display: flex;
		flex-direction: column;
		gap: var(--space-8);
		margin-top: var(--space-6);
		margin-bottom: var(--space-8);
	}

	.experience__item {
		display: grid;
		grid-template-columns: 140px 1fr;
		gap: var(--space-6);
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--color-border);
	}

	.experience__item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.experience__period {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		white-space: nowrap;
	}

	.experience__role {
		font-size: var(--text-lg);
		color: var(--color-heading);
		margin-bottom: var(--space-2);
	}

	.experience__company {
		color: var(--color-accent);
		font-weight: 500;
	}

	.experience__summary {
		color: var(--color-text-muted);
		font-size: var(--text-base);
		line-height: 1.7;
		margin-bottom: var(--space-3);
		max-width: 640px;
	}

	.experience__tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		padding: 0;
		margin: 0;
	}

	.experience__tags li {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		padding: var(--space-1) var(--space-2);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-surface);
		white-space: nowrap;
	}

	.experience__cta {
		font-weight: 600;
		color: var(--color-accent);
		font-size: var(--text-base);
	}

	@media (max-width: 640px) {
		.experience__item {
			grid-template-columns: 1fr;
			gap: var(--space-2);
		}
	}
</style>
