---
import { ICONS, type IconName } from "../../data/icons";

export interface Props {
	name: IconName;
	size?: number;
}

const { name, size = 24 } = Astro.props;
const icon = ICONS[name];
---

<svg
	width={size}
	height={size}
	viewBox={icon.viewBox}
	fill="none"
	stroke="currentColor"
	stroke-width="1.5"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	set:html={icon.markup}
/>
